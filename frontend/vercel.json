{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://talentbridge-backend.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "REACT_APP_API_URL": "https://talentbridge-backend.up.railway.app/api"
  },
  "buildCommand": "npm run build",
  "outputDirectory": "build"
} 